# Supabase Cloud — récupère ces valeurs dans ton Dashboard Supabase
# Project Settings > API
SUPABASE_URL=https://<ton-project-ref>.supabase.co
SUPABASE_KEY=<ta-anon-ou-service-role-key>

# Port d'écoute du serveur (optionnel, défaut: 3000)
PORT=3000

# Mot de passe admin (pour le panneau d'administration)
ADMIN_PASSWORD=changez-moi
